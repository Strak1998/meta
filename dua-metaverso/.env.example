# DUA Metaverso da Lua — Variaveis de Ambiente
# Copia este ficheiro para .env.local e preenche os valores antes de correr.
# NUNCA committes o .env.local — esta listado no .gitignore.

# ── OBRIGATORIAS ────────────────────────────────────────────────────────────

# Segredo JWT para o painel de backstage (min 32 caracteres, aleatorio)
# Gera com: openssl rand -base64 32
BACKSTAGE_JWT_SECRET=change-me-in-production-32-chars!!

# Password do backstage (bcrypt hash preferida)
# Gera hash com: node -e "const b=require('bcryptjs');b.hash('password',10).then(console.log)"
# Em alternativa, define BACKSTAGE_PASSWORD com texto simples (menos seguro)
BACKSTAGE_PASSWORD_HASH=
BACKSTAGE_PASSWORD=backstage2024

# ── OPCIONAIS — LiveKit (voice/video rooms) ──────────────────────────────────
# Obtem em https://cloud.livekit.io — plano gratuito disponivel
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── OPCIONAIS — Vercel KV (estado partilhado entre instancias serverless) ───
# Obtem no dashboard Vercel em Storage > Create KV Store
# Necessario para que o chat funcione correctamente com multiplas instancias.
# Em desenvolvimento, o singleton em memoria e suficiente.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── OPCIONAIS — Segredo partilhado entre servicos internos ──────────────────
# Usado para autenticar requests entre o backstage e os endpoints de eventos
HOST_SECRET=
